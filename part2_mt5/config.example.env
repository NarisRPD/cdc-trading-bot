# ============================================================
#  Part 2 (MT5) — config ตัวอย่าง
#  ก็อปไฟล์นี้เป็น  config.env  แล้วเติมค่าจริง (อย่า commit ค่าจริง)
# ============================================================

# ── สะพานรับสัญญาณจาก Part 1 ──────────────────────────────
PART1_BOT_URL=https://cdc-bot-220154687132.asia-southeast1.run.app
SIGNALS_TOKEN=               # = ค่าเดียวกับ WEBHOOK_SECRET ของ cdc-bot

# ── บัญชี MT5 ─────────────────────────────────────────────
MT5_LOGIN=                   # เลขบัญชี (login)
MT5_PASSWORD=
MT5_SERVER=                  # ชื่อเซิร์ฟเวอร์โบรก (เช่น Exness-MT5Real)
MT5_TERMINAL_PATH=           # path terminal64.exe (เว้นว่างได้ถ้าเปิด terminal อยู่แล้ว)

# ── Risk management (หัวใจของ Part 2) ─────────────────────
ACCOUNT_CURRENCY=USD
RISK_PCT_PER_TRADE=1.0       # เสี่ยงต่อไม้ (% ของพอร์ต) — แนะนำ 1-2
MAX_OPEN_POSITIONS=5         # จำนวนไม้เปิดพร้อมกันสูงสุด
MAX_PER_DIRECTION=3          # ไม้ทิศเดียวกัน (buy หรือ sell) ไม่เกิน N ไม้ (กันเจ็บพร้อมกัน) · 0=ไม่จำกัด
MAX_PER_GROUP=1              # ไม้/กลุ่มสินทรัพย์ ดีฟอลต์ (กระจายเสี่ยง จ-ศ · เสาร์-อาทิตย์ไม่จำกัด) · 0=ปิด
MAX_PER_GROUP_US=2           # กลุ่ม "หุ้น/ดัชนี" (หุ้น+ดัชนี US+ดัชนีโลก) เปิดได้กี่ไม้ (override เพราะมีหลายตัว)
MAX_DAILY_LOSS_PCT=4.0       # ขาดทุนรวมต่อวันเกินนี้ = หยุดออกใบสั่ง (circuit breaker)
MAX_DRAWDOWN_PCT=10.0        # equity ร่วงจากจุดสูงสุดเกิน N% → หยุดหมด+ปิดไม้+แจ้ง (เบรกขาดทุนสะสม) · 0=ปิด
MIN_RR=1.5                   # R:R ต่ำกว่านี้ = ไม่แนะนำ (เป้าใกล้กว่าความเสี่ยง = ไม่คุ้ม)
MAX_RISK_PCT=2.0             # เพดานความเสี่ยงจริง/ไม้ — เกินนี้ข้าม (กันพอร์ตเล็ก+SL กว้าง เช่นทอง)
GOLD_MIN_BALANCE=350         # ปลดล็อกเทรดทอง (XAU) เมื่อพอร์ต ≥ N (ไม้ขั้นต่ำทองใหญ่) · 0=ไม่จำกัด
SILVER_MIN_BALANCE=260       # ปลดล็อกเทรดเงิน (XAG) เมื่อพอร์ต ≥ N · 0=ไม่จำกัด
MAX_SPREAD_PCT=0.15          # spread กว้างเกิน N% ของราคา → ข้าม (เทรดสั้น spread กินกำไร)
COMMISSION_PCT=0.0           # ค่าคอมต่อรอบ (% ของมูลค่า) หักเข้า R:R · 0 = บัญชี spread-only

# ── สินทรัพย์ที่จะเทรดผ่าน MT5 ────────────────────────────
ALLOWED_MARKETS=commodity,us,crypto

# ── Telegram (ใช้แชตเดิม) ─────────────────────────────────
TELEGRAM_BOT_TOKEN=          # บอทตัวที่ 2 (แนะนำ) หรือบอทเดิม
TELEGRAM_CHAT_ID=            # chat id เดิม

# ── การสแกนโบรก (Part 2 สแกนเอง) ──────────────────────────
# SCAN_SYMBOLS ว่าง = ใช้ watchlist ดีฟอลต์ (ทอง/เงิน/น้ำมัน/ดัชนี/FX/คริปโต/เมกะแคป)
# เติมเองได้ เช่น: XAUUSDm,EURUSDm,US30m,NVDAm  (เฉพาะที่โบรกมี ที่ไม่มีจะถูกข้าม)
AUTO_UNIVERSE=false   # true = สแกน 'ทุก symbol ที่โบรกมี' (สินทรัพย์ใหม่รวมเอง · สแกนช้าลง) · false = ใช้ watchlist
SCAN_SYMBOLS=
MARKET_STALE_MIN=180  # ข้ามสินทรัพย์ที่ตลาดปิด (tick เก่ากว่า N นาที) — กันยิงไม่ติด/เสียเวลา
MIN_ATR_PCT=0.5       # ATR/วัน ต่ำกว่า N% = วิ่งช้า → ข้าม (เลือกตัวคึกคัก) · 0 = ไม่กรอง (จัดอันดับอย่างเดียว)
MIN_RECENT_MOVE_PCT=0.7  # ขยับขั้นต่ำ %ช่วงล่าสุด (กันตัว "นิ่งตอนนี้" เช่นคริปโตเสาร์-อาทิตย์) · 0 = ปิด
RECENT_TF=H1          # TF วัดการขยับล่าสุด
RECENT_BARS=12        # ดูย้อนหลังกี่แท่ง (12 × H1 = ~12 ชม.)
TREND_TF=D1            # TF ดูเทรนด์/CDC
ENTRY_TF=H1           # TF จับจังหวะเข้า (แท่งเทียน/วอลุ่ม)
TP_RR=2.0             # TP = ระยะ SL × ค่านี้ (สอดคล้อง SL อัตโนมัติ)
SL_ATR_MULT=1.5       # SL = กันชน N×ATR (ลด=แคบ lot ใหญ่ · เพิ่ม=กว้าง ทน noise)
SL_LOOKBACK=20        # SL วางใต้/เหนือ swing N แท่งล่าสุด
USE_3BP_SL=true       # เจอ 3-Bar Play → ใช้ SL ใต้/เหนือแท่งพัก (แคบ R:R ดี) · false=ใช้ swing/ATR
THREEBP_TF=M15        # TF จับ 3-Bar Play (ไวกว่า ENTRY_TF — จับโมเมนตัม NY เปิด/ทองข่าว) · ว่าง=ใช้ ENTRY_TF
USE_3BP_TP=false      # true = TP เท่าความยาวแท่ง1 (ต้นตำรับ) ถ้า R:R ยังคุ้ม · false = TP 2R ปกติ
USE_BRT_SL=true       # เจอ Breakout & Retest → ใช้ SL ใต้/เหนือแนวที่เพิ่งเบรก · false=ใช้ swing/ATR
USE_IBB_SL=true       # เจอ Inside Bar Breakout → ใช้ SL ใต้/เหนือ Inside Bar
USE_TLP_SL=true       # เจอ 2-Legged Pullback → ใช้ SL ใต้/เหนือ Leg2
TEST_BALANCE=1000     # ใช้คำนวณ lot ตอน balance=0 (โชว์ตัวอย่าง)

# ── โหมดโต้ตอบ (interactive.py) ───────────────────────────
EXECUTE_ORDERS=false   # false = โหมดทดสอบ (ไม่ยิงจริง) · true = ยิงออเดอร์จริง
AUTO_TRADE=false       # true = บอทตัดสินใจ+ยิงเอง (ไม่ต้องกดปุ่ม รายงานผ่าน Telegram) · false = ส่งใบให้กดเอง
# ความเข้ม Gemini: รับ decision ไหนบ้าง (คั่นด้วย ,)
#   enter        = เข้มสุด (เฉพาะตัวที่ AI มั่นใจ)
#   enter,small  = สมดุล (default — รวมไม้เสี่ยงสูงด้วย)
#   enter,small,manual = ผ่อน (รวมตอน AI ใช้ไม่ได้/timeout)
GEMINI_ACCEPT=enter,small
CDC_LEAD=false         # true = เชื่อ CDC เป็นหลัก (Gemini ไม่ veto ทิ้ง แค่ลดขนาดไม้) · false = CDC+Gemini กรอง
SMALL_RISK_MULT=0.5    # ไม้ที่ AI ขอระวัง (small/skip) เสี่ยงเท่าไหร่ของปกติ (0.5 = ครึ่งเดียว)
AI_VETO_CONF=80        # โหมด CDC นำ: AI ห้าม (skip) ด้วยความมั่นใจ ≥ N% → เชื่อ AI ข้ามทันที
RSI_OVERSOLD=25        # ไม่ช็อตถ้า RSI < N (กันขายก้นเหว/เด้งสวน)
RSI_OVERBOUGHT=75      # ไม่ long ถ้า RSI > N (กันซื้อยอดดอย)
# ── Scalp เติมจังหวะระหว่างวัน (ตามเทรนด์ — เปิดเมื่อพร้อม แนะนำเริ่มเดโม/ไม้เล็ก) ──
USE_EMA_STOCH=false    # true = เปิด EMA Ribbon+Stochastic บน M15 (เลี่ยง FX) เติมไม้ระหว่างรอ CDC · backtest +13R
SCALP_RR=1.8           # TP ของไม้ scalp = N × ระยะ SL (ตั้งที่โบรก ปิดไว ไม่โดนกฎ TP +2%)
USE_FX_ORB=false       # true = เปิด Asian-London ORB เฉพาะ FX (เบรกกรอบเอเชียตอน London เปิด ~14:00 ไทย) · backtest +7R
USE_HYBRID_PRO=false   # true = เปิด Hybrid-Pro (H1 เทรนด์ + M15 ย่อ EMA20 + RSI 40-60 + แท่งกลับตัว) เลี่ยง FX
HYBRID_RR=2.5          # TP ของ Hybrid-Pro = N × ระยะ SL
SCALP_WEEKEND_LOOSEN=true  # เสาร์-อาทิตย์: ผ่อนเกณฑ์ scalp ให้ไวขึ้น (Stoch 30/70 · RSI 35-65) เพราะคริปโตวอลุ่มน้อย
TICKET_TTL_SEC=180     # ใบสั่งหายถ้าไม่ตอบใน N วินาที (180 = 3 นาที)
SCAN_INTERVAL_MIN=5    # เว้น N นาทีค่อยสแกนหาใบใหม่
NOTIFY_SCAN=true       # แจ้งสรุปการสแกนเข้า Telegram (ตัวที่เปิด + ตัวที่ข้าม) · false=ไม่แจ้ง
DIGEST_HOUR=8          # ชั่วโมงส่งสรุปประจำวัน (Telegram) · 8 = 8 โมงเช้า (ครั้งเดียว/วัน)
SYMBOL_COOLDOWN_SEC=0     # เว้น N วินาทีก่อนเข้าตัวเดิมซ้ำ (0 = ไม่จำกัด เข้าได้ทันทีถ้าเทคนิคยังเข้าเงื่อนไข)

# ── Trade management (จัดการไม้หลังเปิด) ──
TP_PRICE_PCT=2.0      # ราคาขยับถึง N% ทางกำไร → ปิดทั้งไม้ทันที (0 = ไม่ใช้ ใช้ R-based แทน)
CLOSE_BEFORE_MARKET_CLOSE=true  # ตลาดใกล้ปิด + (ไม้กำไร หรือ พอร์ตวันนี้เขียว) → ปิดไม้นั้นทันที (ไม่รวมคริปโต)
MARKET_CLOSE_BUFFER_MIN=20      # ปิดก่อนตลาดปิดกี่นาที
PARTIAL_AT_R=1.0      # กำไรถึง +N R → ปิดบางส่วน + เลื่อน SL เท่าทุน (R = ระยะ SL เริ่มต้น)
HARD_TP_R=2.5         # กำไรถึง +N R → ปิดทันที (เพดาน) · TP ราคาปกติ = 2R
PARTIAL_RATIO=0.5     # ปิดบางส่วนสัดส่วนเท่าไหร่ (0.5 = ครึ่งหนึ่ง)
TRAIL_FACTOR=0.7      # ระยะ trailing SL = R × ค่านี้ (เล็ก=เก็บใกล้ยอด)

# ── เลี่ยงข่าวแรง + AI gate ───────────────────────────────
GEMINI_API_KEY=       # คีย์ Gemini (ด่านปิดช่องโหว่)
FINNHUB_API_KEY=      # = ค่าเดียวกับ Part 1 (เว้นว่าง = ปิดฟีเจอร์เลี่ยงข่าว)
BLACKOUT_MIN=30       # งดเปิดไม้ ±N นาที รอบข่าว US high-impact (NFP/FOMC/CPI)

# ── การเรียนรู้จากผลจริง (closed-loop) ────────────────────
LEARN_MIN_SAMPLES=10   # ต้องมีไม้ปิด ≥N ไม้ ก่อนป้อน "บทเรียน" เข้า Gemini (กัน overfit จากตัวอย่างน้อย)

# ── รอบ poll ──────────────────────────────────────────────
POLL_MINUTES=15
