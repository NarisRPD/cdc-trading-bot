# ============================================================
#  Part 2 (MT5) — config ตัวอย่าง
#  ก็อปไฟล์นี้เป็น  config.env  แล้วเติมค่าจริง (อย่า commit ค่าจริง)
# ============================================================

# ── สะพานรับสัญญาณจาก Part 1 ──────────────────────────────
PART1_BOT_URL=https://cdc-bot-220154687132.asia-southeast1.run.app
SIGNALS_TOKEN=               # = ค่าเดียวกับ WEBHOOK_SECRET ของ cdc-bot

# ── บัญชี MT5 ─────────────────────────────────────────────
MT5_LOGIN=                   # เลขบัญชี (login)
MT5_PASSWORD=
MT5_SERVER=                  # ชื่อเซิร์ฟเวอร์โบรก (เช่น Exness-MT5Real)
MT5_TERMINAL_PATH=           # path terminal64.exe (เว้นว่างได้ถ้าเปิด terminal อยู่แล้ว)

# ── Risk management (หัวใจของ Part 2) ─────────────────────
ACCOUNT_CURRENCY=USD
RISK_PCT_PER_TRADE=1.0       # เสี่ยงต่อไม้ (% ของพอร์ต) — แนะนำ 1-2
MAX_OPEN_POSITIONS=5         # จำนวนไม้เปิดพร้อมกันสูงสุด
MAX_PER_DIRECTION=3          # ไม้ทิศเดียวกัน (buy หรือ sell) ไม่เกิน N ไม้ (กันเจ็บพร้อมกัน) · 0=ไม่จำกัด
MAX_PER_GROUP=1              # ไม้/กลุ่มสินทรัพย์ ดีฟอลต์ (กระจายเสี่ยง จ-ศ · เสาร์-อาทิตย์ไม่จำกัด) · 0=ปิด
MAX_PER_GROUP_US=2           # กลุ่ม "หุ้น/ดัชนี" (หุ้น+ดัชนี US+ดัชนีโลก) เปิดได้กี่ไม้ (override เพราะมีหลายตัว)
MAX_DAILY_LOSS_PCT=4.0       # ขาดทุนรวมต่อวันเกินนี้ = หยุดออกใบสั่ง (circuit breaker)
MAX_DRAWDOWN_PCT=10.0        # equity ร่วงจากจุดสูงสุดเกิน N% → หยุดเปิดไม้ใหม่+แจ้ง (เบรกขาดทุนสะสม) · 0=ปิด
DRAWDOWN_CLOSE_POSITIONS=false # true = ปิดไม้ทั้งหมดด้วยตอนชน drawdown · false = หยุดอย่างเดียว ปล่อยไม้เดิมถึง SL เอง
MIN_RR=1.5                   # R:R ต่ำกว่านี้ = ไม่แนะนำ (เป้าใกล้กว่าความเสี่ยง = ไม่คุ้ม)
MIN_RR_HYBRID=1.30           # Hybrid-Pro (H1+M15+RSI+แท่ง) — มี filter เยอะ ผ่อน R:R ได้
# ── Entry quality filters (ลดไม้ "เข้าแล้วแดงยาวจน SL") ─────────────────
# แนะนำเปิด MTF ก่อนตัวเดียว ดูผล 1-2 สัปดาห์ ค่อยเพิ่มตัวอื่น (เปิดหมดพร้อมกัน = ไม้น้อยมาก)
USE_MTF_FILTER=false         # true = ไม่เข้าสวนเทรนด์ TF ใหญ่ (ยกเว้น vwap/rsi_div ที่สวนตั้งใจ) ⭐แนะนำเปิด
MTF_TF=H1                    # TF ใหญ่เช็คเทรนด์ (EMA50 vs EMA200) · entry M15 → ใช้ H1 · entry H1 → ใช้ H4
MTF_INCLUDE_MEANREV=false    # true = บังคับ vwap/rsi_div เคารพ MTF ด้วย (กัน crypto สวนเทรนด์แดงตั้งแต่เข้า) ⭐เปิดถ้าเทรด crypto
REQUIRE_BAR_CLOSE=false      # true = ข้ามไม้ที่ "ไล่ราคา" (แท่งวิ่งไกลไปแล้ว) — กันเข้ายอด/ก้น
CHASE_ATR_MULT=0.7          # แท่งปัจจุบันวิ่งเกิน N×ATR ในทิศเทรด = ไล่ราคา → ข้าม
REQUIRE_ENTRY_CONFIRM=false  # true = ต้องมีแท่งยืนยัน/volume/pattern ≥1 ถึงเข้า (กันไม้เปล่า)
# ── Pro Scalping Filters (Kill Zone/Liquidity Sweep/Momentum/VWAP) ───────────
# ใช้กับกลยุทธ์ scalp/สั้นเท่านั้น (vwap/rsi_div/bb_squeeze/ema_m5/orb_pro/fx_orb/scalp/utbot/hybrid)
# ดึง M5 มาตรวจ · ระบบให้คะแนน — ผ่านถ้า score ≥ SCALP_FILTER_MIN_SCORE
USE_SCALP_FILTERS=false           # true = เปิด · ⚠️ opt-in (กรองหนัก ไม้น้อยลงแต่คุณภาพสูง)
SCALP_FILTER_TF=M5                # TF ที่ดึงมาตรวจ filters
SCALP_FILTER_BARS=300             # จำนวนแท่ง M5 (300 = ~25 ชม. ครอบ VWAP/session)
SCALP_FILTER_MIN_SCORE=2          # ต้องได้ score ≥ N จาก filters ที่เปิด ถึงผ่าน
SCALP_FILTER_KILL_ZONE=true       # เข้าเฉพาะ London/NY Kill Zone · ⚠️ crypto 24/7 ปิดถ้าไม่อยากจำกัด
SCALP_KILL_ZONES=london_open,ny_open  # london_open(07-09) · ny_open(13-15:30) · london_close(15-16) UTC
SCALP_FILTER_DEAD_ZONE=true       # บล็อก Asian dead zone (23:00-06:30 UTC) — volume ต่ำ noise สูง
SCALP_FILTER_LIQ_SWEEP=true       # ตรวจ liquidity sweep (กวาด stop แล้วกลับ)
SCALP_FILTER_LIQ_REQUIRED=false   # false=เป็น bonus · true=บังคับต้องมี sweep
SCALP_LIQ_LOOKBACK=20             # แท่งย้อนหลังหา swing
SCALP_LIQ_SWEEP_BARS=3            # แท่งล่าสุดที่ตรวจ sweep
SCALP_FILTER_MOMENTUM=true        # ต้องมี momentum confirm (ADX + แท่งต่อเนื่อง) — กัน "แดงตั้งแต่เข้า"
SCALP_ADX_MIN=20                  # ADX ขั้นต่ำ (ต่ำกว่า = sideways ไม่เข้า)
SCALP_MOMENTUM_BARS=2             # จำนวนแท่งยืนยันทิศ
SCALP_BODY_RATIO=0.4              # body ratio ขั้นต่ำ (กัน doji)
SCALP_FILTER_VWAP=true            # ตรวจ VWAP distance (ไม่ชิด/ไม่ไกลเกิน)
SCALP_VWAP_MIN_DIST=0.3           # ระยะ min จาก VWAP (×ATR) — ชิดกว่า = sideways
SCALP_VWAP_MAX_DIST=3.0           # ระยะ max จาก VWAP (×ATR) — ไกลกว่า = mean reversion risk
# ── Multi-Strategy Confluence (Confirmation mode) ─────────────────────
# หลายกลยุทธ์ entry อิสระเห็นพ้อง symbol+direction เดียวกัน = สัญญาณแข็งแรง → เพิ่ม lot
# *** ไม่ลดจำนวนไม้ *** — ไม้ confluence แค่ได้ lot ใหญ่ขึ้น (cap ที่ MAX_RISK_PCT)
USE_CONFLUENCE=true          # true = เปิด confluence boost · false = ปิด (ทุกไม้ lot ปกติ)
CONFLUENCE_MIN_COUNT=2       # ต้องมี ≥ N กลยุทธ์เห็นพ้อง ถึง boost (2 = อย่างน้อย 2 ตัว)
CONFLUENCE_LOT_MULT=1.5      # boost lot กี่เท่าเมื่อ confluence (1.5 = +50% · cap ไม่เกิน MAX_RISK_PCT)
# ── Opening/Closing Range Protection (US stocks/indices) ──────────────
US_OPEN_SKIP_MIN=30          # งดเปิดไม้ N นาทีแรกหลัง US market เปิด (20:30→21:00 ไทย)
US_CLOSE_SKIP_MIN=15         # งดเปิดไม้ N นาทีก่อน US market ปิด (02:45→03:00 ไทย)
MAX_RISK_PCT=2.0             # เพดานความเสี่ยงจริง/ไม้ — เกินนี้ข้าม (กันพอร์ตเล็ก+SL กว้าง เช่นทอง)
GOLD_MIN_BALANCE=350         # ปลดล็อกเทรดทอง (XAU) เมื่อพอร์ต ≥ N (ไม้ขั้นต่ำทองใหญ่) · 0=ปลดล็อกเลย
SILVER_MIN_BALANCE=260       # ปลดล็อกเทรดเงิน (XAG) เมื่อพอร์ต ≥ N · 0=ปลดล็อกเลย
TRADE_FX=true                # true=เทรด FX ปกติ · false=ปิด FX ทั้งหมด (FX ขยับน้อย ไม่เหมาะ scalp)
TRADE_INDEX=true             # true=เทรดดัชนีทุกตัว · false=ปิดดัชนีที่ไม่ใช่ US ยกเว้น INDEX_ALLOW (ดัชนี US เทรดเสมอ)
INDEX_ALLOW=JP225,HK50       # ดัชนีนอก US ที่ยังเทรดได้แม้ TRADE_INDEX=false (ญี่ปุ่น Nikkei · ฮ่องกง Hang Seng)
MAX_SPREAD_PCT=0.15              # spread สูงสุด FX (EURUSD ~0.01-0.03% ปกติ)
MAX_SPREAD_PCT_COMMODITY=0.80   # commodity: XAU ~0.03% · XPDUSD(Palladium) ~0.5-0.8% ปกติ
MAX_SPREAD_PCT_STOCK=0.40       # US stock CFD: spread ปกติ 0.05-0.15% · pre-market ยกเว้น (is_open filter)
MAX_SPREAD_PCT_INDEX=0.20       # US30/US500/USTEC spread ปกติ 0.03-0.10%
MAX_SPREAD_PCT_EU_INDEX=0.22    # STOXX50m/UK100m/DAX spread กว้างกว่า US index (~0.10-0.20%)
MAX_SPREAD_PCT_CRYPTO=1.0       # crypto: BNB ~0.35% · XRP ~0.9% ปกติ
COMMISSION_PCT=0.0           # ค่าคอมต่อรอบ (% ของมูลค่า) หักเข้า R:R · 0 = บัญชี spread-only

# ── สินทรัพย์ที่จะเทรดผ่าน MT5 ────────────────────────────
ALLOWED_MARKETS=commodity,us,crypto

# ── Telegram (ใช้แชตเดิม) ─────────────────────────────────
TELEGRAM_BOT_TOKEN=          # บอทตัวที่ 2 (แนะนำ) หรือบอทเดิม
TELEGRAM_CHAT_ID=            # chat id เดิม

# ── การสแกนโบรก (Part 2 สแกนเอง) ──────────────────────────
# SCAN_SYMBOLS ว่าง = ใช้ watchlist ดีฟอลต์ (ทอง/เงิน/น้ำมัน/ดัชนี/FX/คริปโต/เมกะแคป)
# เติมเองได้ เช่น: XAUUSDm,EURUSDm,US30m,NVDAm  (เฉพาะที่โบรกมี ที่ไม่มีจะถูกข้าม)
AUTO_UNIVERSE=false   # true = สแกน 'ทุก symbol ที่โบรกมี' (สินทรัพย์ใหม่รวมเอง · สแกนช้าลง) · false = ใช้ watchlist
SCAN_SYMBOLS=
MARKET_STALE_MIN=180  # ข้ามสินทรัพย์ที่ตลาดปิด (tick เก่ากว่า N นาที) — กันยิงไม่ติด/เสียเวลา
MIN_ATR_PCT=0.5       # ATR/วัน ต่ำกว่า N% = วิ่งช้า → ข้าม (เลือกตัวคึกคัก) · 0 = ไม่กรอง (จัดอันดับอย่างเดียว)
MIN_RECENT_MOVE_PCT=0.7  # ขยับขั้นต่ำ %ช่วงล่าสุด (กันตัว "นิ่งตอนนี้" เช่นคริปโตเสาร์-อาทิตย์) · 0 = ปิด
RECENT_TF=H1          # TF วัดการขยับล่าสุด
RECENT_BARS=12        # ดูย้อนหลังกี่แท่ง (12 × H1 = ~12 ชม.)
ENTRY_TF=H1           # TF จับจังหวะเข้า (แท่งเทียน/วอลุ่ม)
TP_RR=2.0             # TP = ระยะ SL × ค่านี้ (สอดคล้อง SL อัตโนมัติ)
SL_ATR_MULT=1.5       # SL = กันชน N×ATR (ลด=แคบ lot ใหญ่ · เพิ่ม=กว้าง ทน noise)
SL_LOOKBACK=20        # SL วางใต้/เหนือ swing N แท่งล่าสุด
USE_3BP_SL=true       # เจอ 3-Bar Play → ใช้ SL ใต้/เหนือแท่งพัก (แคบ R:R ดี) · false=ใช้ swing/ATR
THREEBP_TF=M15        # TF จับ 3-Bar Play (ไวกว่า ENTRY_TF — จับโมเมนตัม NY เปิด/ทองข่าว) · ว่าง=ใช้ ENTRY_TF
USE_3BP_TP=false      # true = TP เท่าความยาวแท่ง1 (ต้นตำรับ) ถ้า R:R ยังคุ้ม · false = TP 2R ปกติ
USE_BRT_SL=true       # เจอ Breakout & Retest → ใช้ SL ใต้/เหนือแนวที่เพิ่งเบรก · false=ใช้ swing/ATR
USE_IBB_SL=true       # เจอ Inside Bar Breakout → ใช้ SL ใต้/เหนือ Inside Bar
USE_TLP_SL=true       # เจอ 2-Legged Pullback → ใช้ SL ใต้/เหนือ Leg2
TEST_BALANCE=1000     # ใช้คำนวณ lot ตอน balance=0 (โชว์ตัวอย่าง)

# ── VPOC Filter + TP Zone ──────────────────────────────────
USE_VPOC=true         # true = เปิด VPOC (ปิดถ้าไม่ต้องการ)
VPOC_TF=M5            # TF ดึง Volume Profile (M5=288bars=24h ครอบทุก session)
VPOC_BARS=288         # 288×M5 = 24h
VPOC_FILTER_ATR=0.5   # ราคาใกล้ VPOC < N×ATR → ลด lot (ตลาดสมดุล ยังไม่มีทิศ)
VPOC_LOT_REDUCE=0.4   # เหลือ 40% เมื่อ near VPOC · ปรับสูง=เสี่ยงมากขึ้น ต่ำ=ระวังมากขึ้น
VPOC_MIN_RR=1.5       # VPOC ต้องอยู่ใน ≥ N×R ถึงจะใช้เป็น TP · ต่ำกว่า MIN_RR = ใช้ fixed R:R ปกติ

# ── โหมดโต้ตอบ (interactive.py) ───────────────────────────
EXECUTE_ORDERS=false   # false = โหมดทดสอบ (ไม่ยิงจริง) · true = ยิงออเดอร์จริง
AUTO_TRADE=false       # true = บอทตัดสินใจ+ยิงเอง (ไม่ต้องกดปุ่ม รายงานผ่าน Telegram) · false = ส่งใบให้กดเอง
# ความเข้ม Gemini: รับ decision ไหนบ้าง (คั่นด้วย ,)
#   enter        = เข้มสุด (เฉพาะตัวที่ AI มั่นใจ)
#   enter,small  = สมดุล (default — รวมไม้เสี่ยงสูงด้วย)
#   enter,small,manual = ผ่อน (รวมตอน AI ใช้ไม่ได้/timeout)
GEMINI_ACCEPT=enter,small
SMALL_RISK_MULT=0.5    # ไม้ที่ AI ขอระวัง (small) เสี่ยงเท่าไหร่ของปกติ (0.5 = ครึ่งเดียว)
RSI_OVERSOLD=30        # ไม่ช็อตถ้า RSI < N — ใช้กับ crypto/FX/หุ้น (กันขายก้นเหว)
RSI_OVERBOUGHT=75      # ไม่ long ถ้า RSI > N — ใช้กับ crypto/FX/หุ้น (กันซื้อยอดดอย)
RSI_OVERSOLD_COMMODITY=20   # threshold สำหรับทอง/น้ำมัน — วิ่ง oversold ได้ลึกกว่า
RSI_OVERBOUGHT_COMMODITY=82 # threshold สำหรับทอง/น้ำมัน — bull trend RSI 80+ เป็นเรื่องปกติ
# ── Scalp เติมจังหวะระหว่างวัน (ตามเทรนด์ — เปิดเมื่อพร้อม แนะนำเริ่มเดโม/ไม้เล็ก) ──
# กลยุทธ์ trend ทั้งหมดเป็น opt-in (ดีฟอลต์ false) — ต้องตั้ง true เองถึงจะเปิด · กันเปิดเองตอน config reset
USE_SUPERTREND=false   # false = ปิด SuperTrend H1 · true = เปิด (สัญญาณหลักตามเทรนด์)
USE_UTBOT=false        # false = ปิด UT Bot M15 (ATR trailing stop crossover ตอบสนองไว) · true = เปิด
USE_HALFTREND=false    # false = ปิด HalfTrend (ตอบสนองช้า โดน SL บ่อยในตลาดผันผวน) · true = เปิด
USE_EMA_STOCH=false    # true = เปิด EMA Ribbon+Stochastic บน M15 (เลี่ยง FX) เติมไม้ scalp · backtest +13R
SCALP_RR=1.8           # TP ของไม้ scalp = N × ระยะ SL (ตั้งที่โบรก ปิดไว ไม่โดนกฎ TP +2%)
USE_FX_ORB=false       # true = เปิด Asian-London ORB เฉพาะ FX (เบรกกรอบเอเชียตอน London เปิด ~14:00 ไทย) · backtest +7R
USE_HYBRID_PRO=false   # true = เปิด Hybrid-Pro (H1 เทรนด์ + M15 ย่อ EMA20 + RSI 40-60 + แท่งกลับตัว) เลี่ยง FX
HYBRID_RR=2.5          # TP ของ Hybrid-Pro = N × ระยะ SL
USE_PA=false           # true = เปิด Price Action & Market Structure (H1 โครงสร้าง HH/HL + S/R + แท่งกลับตัว)
# ── EMA Ribbon Scalp (M5) — กลยุทธ์ scalp FX 5-10 นาที ระดับ prop firm ──────
# ใช้โดย: SMB Capital, T3 Trading, Warrior Trading (New York prop desks)
# EMA 8 ตัด EMA 21 + RSI 40-65 (momentum zone) → เข้าเร็วออกเร็ว ไม่รอ H1 flip
USE_EMA_M5=false       # true = เปิด EMA Ribbon M5 สำหรับ FX scalp (5-10 นาที)
EMA_M5_TF=M5           # TF ของ scanner (M5 แนะนำ · M1 เร็วกว่าแต่ noise มากกว่า)
EMA_FAST=8             # EMA fast period
EMA_SLOW=21            # EMA slow period
EMA_RSI_MIN=40         # RSI ต่ำสุด (กัน sell ตอน oversold)
EMA_RSI_MAX=65         # RSI สูงสุด (กัน buy ตอน overbought) — 65 ไม่ใช่ 70 เพราะ scalp ต้องเข้าก่อนคนอื่น
EMA_SL_ATR=1.0         # SL = EMA slow ± N×ATR(M5) (1.0 = แน่นเหมาะ scalp · 1.5 = หลวมกว่า)
EMA_M5_RR=2.0          # R:R ของ EMA M5 scalp (จะถูก override ถ้าตั้ง TP_ATR_MULT)
FX_SCALP_SYMBOLS=EURUSD,GBPUSD,USDJPY,AUDUSD  # FX pairs ที่สแกน (เฉพาะ volume สูง)
TP_ATR_MULT=0          # TP = ATR × N (0 = ใช้ R:R ปกติ · 2.0 = TP สมจริงตามความผันผวน)
PA_TF=H1               # TF ตรวจโครงสร้างตลาด (แนะนำ H1 — สมดุลระหว่าง noise กับ ความเร็ว)
PA_RR=2.0              # TP ของ Price Action = N × ระยะ SL
SCALP_WEEKEND_LOOSEN=true  # เสาร์-อาทิตย์: ผ่อนเกณฑ์ scalp ให้ไวขึ้น (Stoch 30/70 · RSI 35-65) เพราะคริปโตวอลุ่มน้อย
TICKET_TTL_SEC=180     # ใบสั่งหายถ้าไม่ตอบใน N วินาที (180 = 3 นาที)
SCAN_INTERVAL_MIN=5    # เว้น N นาทีค่อยสแกนหาใบใหม่
NOTIFY_SCAN=false      # แจ้งสรุปการสแกนเข้า Telegram · false=ดูใน log แทน (ลด spam) · true=แจ้งทุก skip
HEARTBEAT_MIN=0        # แจ้งสถานะบอทใน Telegram ทุก N นาที (0=ปิด · แนะนำ 60 ถ้าอยากตรวจว่าบอทยังทำงาน)
DIGEST_HOUR=8          # ชั่วโมงส่งสรุปประจำวัน (Telegram) · 8 = 8 โมงเช้า (ครั้งเดียว/วัน)
SYMBOL_COOLDOWN_SEC=0     # เว้น N วินาทีก่อนเข้าตัวเดิมซ้ำ (0 = ไม่จำกัด เข้าได้ทันทีถ้าเทคนิคยังเข้าเงื่อนไข)

# ── Trade management (จัดการไม้หลังเปิด) ──
TP_PRICE_PCT=2.0      # ราคาขยับถึง N% ทางกำไร → ปิดทั้งไม้ทันที (0 = ไม่ใช้ ใช้ R-based แทน)
CLOSE_BEFORE_MARKET_CLOSE=true  # ตลาดใกล้ปิด → ปิด "ไม้กำไร" ทันที (กฎ: ขาดทุนไม่ปิด · ไม่รวมคริปโต)
MARKET_CLOSE_BUFFER_MIN=20      # ปิดก่อนตลาดปิดกี่นาที
CLOSE_LOSERS_ON_GREEN_DAY=false # true = ปิด "ไม้ขาดทุน" ด้วยถ้าวันนี้พอร์ตเขียว (ดีฟอลต์ false = ขาดทุนไม่ปิด)
PARTIAL_AT_R=1.0      # กำไรถึง +N R → ปิดบางส่วน (เก็บกำไรก้อนแรก) — SL ยังอยู่ที่เดิม!
BREAKEVEN_AT_R=1.5   # กำไรถึง +N R → เลื่อน SL เท่าทุน (แยกจาก partial — ให้ราคาหายใจระหว่าง 1R-1.5R)
HARD_TP_R=2.5         # กำไรถึง +N R → ปิดทั้งหมดทันที (เพดาน)
PARTIAL_RATIO=0.5     # ปิดบางส่วนสัดส่วนเท่าไหร่ (0.5 = ครึ่งหนึ่ง)
TRAIL_FACTOR=0.7            # ระยะ trailing SL = max(R, ATR) × ค่านี้ (0.7=ค่อนข้างแน่น · 1.0=หลวม)
TRAIL_FACTOR_US_STOCK=1.2   # US stocks/indices: tick size ใหญ่กว่า FX → trailing ต้องห่างกว่า (กัน retcode 10025)
USE_REVERSAL_EXIT=false  # true = ปิดก่อนชน SL ถ้าเจอ reversal candle แรงบน M5 ขณะกำไรอยู่
REVERSAL_EXIT_MIN_R=0.5  # min กำไร (R) ก่อนเช็ค reversal exit (กันออกเร็วไปหลังเพิ่งเข้า)
REVERSAL_EXIT_TF=M5      # TF ตรวจ reversal candle (M1/M5/M15)
# ── Multi-signal exit — ปิดเมื่อ SuperTrend (เทคนิคเทรนด์) พลิกสวนทาง position ──
# เข้าด้วยเทคนิคไหนก็ได้ แต่ถ้าเทรนด์ระบบเปลี่ยนข้าง → ออกตามสัญญาณใหม่ (เปลี่ยนเทคนิคกลางทาง)
USE_MULTI_SIGNAL_EXIT=false  # true = เปิด · ⚠️ opt-in (ออกไวขึ้น แต่เสี่ยง whipsaw ตัดของดีทิ้ง)
MULTI_EXIT_MIN_R=0.3         # min กำไร (R) ก่อนเช็ค (กันออกเร็วหลังเพิ่งเข้า)
MULTI_EXIT_TF=M15           # TF ตรวจ SuperTrend flip (M15 สมดุล · M5 ไวกว่าแต่ noise มาก)

# ── เลี่ยงข่าวแรง + AI gate ───────────────────────────────
GEMINI_API_KEY=       # คีย์ Gemini (ด่านปิดช่องโหว่)
FINNHUB_API_KEY=      # = ค่าเดียวกับ Part 1 (เว้นว่าง = ปิดฟีเจอร์เลี่ยงข่าว)
BLACKOUT_MIN=30       # งดเปิดไม้ ±N นาที รอบข่าว US high-impact (NFP/FOMC/CPI)

# ── การเรียนรู้จากผลจริง (closed-loop) ────────────────────
LEARN_MIN_SAMPLES=10   # ต้องมีไม้ปิด ≥N ไม้ ก่อนป้อน "บทเรียน" เข้า Gemini (กัน overfit จากตัวอย่างน้อย)
# ── Auto-disable เทคนิคที่แพ้ (ใช้ผลเทรดจริงนำ) ──────────────
AUTO_DISABLE_LOSERS=true    # true = ข้ามกลยุทธ์/symbol ที่ win-rate ต่ำกว่าเกณฑ์อัตโนมัติ
AUTO_DISABLE_MIN_TRADES=8   # ต้องมีไม้ปิด ≥N ไม้ ถึงจะ disable (กัน disable เพราะตัวอย่างน้อย)
AUTO_DISABLE_WINRATE=35     # win-rate ต่ำกว่า N% (ในไม้พอ) → ข้ามตัวนั้นเอง
# ── Auto lot by edge — ปรับ lot ตาม edge จริง (avg R-multiple) ──
USE_EDGE_SIZING=false       # true = เปิด · ⚠️ opt-in (ต้องมีข้อมูลพอก่อน · เปลี่ยนขนาดไม้อัตโนมัติ)
EDGE_SIZING_MIN_TRADES=10   # ต้องมีไม้ปิด ≥N ต่อกลยุทธ์ ถึงจะปรับ lot
EDGE_SIZING_MIN_MULT=0.5    # edge แย่ (avg_r ≤ 0) → lot × ค่านี้ (เล็กสุด)
EDGE_SIZING_MAX_MULT=1.5    # edge ดี (avg_r ≥ 1R) → lot × ค่านี้ (ใหญ่สุด · cap ที่ MAX_RISK_PCT)

# ── รอบ poll ──────────────────────────────────────────────
POLL_MINUTES=15

# ══════════════════════════════════════════════════════════════════════════════
# SCALP SUITE — 4 กลยุทธ์ระดับ prop firm / institutional (5-10 นาที)
# เปิดทีละอัน ทดสอบก่อน แนะนำ: USE_VWAP → USE_BB_SQUEEZE → USE_RSI_DIV → USE_ORB_PRO
# ══════════════════════════════════════════════════════════════════════════════

# ── 1. VWAP Bounce (Jane Street / Citadel style) ──────────────────────────
USE_VWAP=false         # true = เปิด VWAP Bounce (ราคา pullback มาแตะ VWAP แล้วเด้ง)
VWAP_TF=M5             # TF ของ scanner
VWAP_STD_ENTRY=0.5     # ต้องออกห่าง VWAP ≥ N×σ ก่อนจะนับว่า "ออกนอก" (0.5 = แน่น)
VWAP_STD_SL=1.5        # SL = VWAP ± N×σ (1.5 = ถ้า VWAP ถูกทะลุจริงๆ → ออก)
VWAP_RSI_MIN=35        # RSI ขั้นต่ำ (กัน sell ตอน oversold)
VWAP_RSI_MAX=65        # RSI สูงสุด (กัน buy ตอน overbought)
VWAP_RR=2.0            # R:R สำหรับ VWAP Bounce

# ── 2. BB Squeeze Breakout (momentum hedge fund style) ───────────────────
USE_BB_SQUEEZE=false   # true = เปิด Bollinger Band Squeeze (BB แคบ → จับ momentum burst)
BB_TF=M5               # TF ของ scanner
BB_PERIOD=20           # BB period (Bollinger standard = 20)
BB_STD=2.0             # BB standard deviation (2.0 = standard · 1.5 = แน่นกว่า)
BB_SQUEEZE_LOOKBACK=50 # วัด squeeze จาก N bars ย้อนหลัง
BB_VOL_MULT=1.2        # volume ต้อง > avg × N ยืนยัน breakout (1.0 = ปิด filter)
BB_RR=2.0              # R:R สำหรับ BB Squeeze

# ── 3. RSI Divergence M5 (discretionary trader standard) ─────────────────
USE_RSI_DIV=false      # true = เปิด RSI Divergence (ราคาไปต่อแต่ RSI ไม่ยืนยัน)
RSI_DIV_TF=M5          # TF ของ scanner
RSI_DIV_PERIOD=14      # RSI period (Wilder's standard = 14)
RSI_DIV_LOOKBACK=30    # มองย้อนหลัง N bars หา swing high/low
RSI_DIV_SWING=2        # swing strength (bars ทั้ง 2 ข้างต้องต่ำ/สูงกว่า pivot)
RSI_DIV_RR=2.0         # R:R สำหรับ RSI Divergence

# ── 4. Opening Range Breakout / ORB (Toby Crabel 1990 · 30+ ปีในกองทุน) ──
USE_ORB_PRO=false      # true = เปิด ORB (เฉพาะ FX pairs · ช่วง session open เท่านั้น)
ORB_SESSION=london     # london (07 UTC) · ny (13 UTC) · both (ทั้ง 2 session)
ORB_RANGE_BARS=3       # M5 bars สร้าง opening range (3 bars = 15 นาที แรก)
ORB_WINDOW_MIN=90      # เทรดได้แค่ N นาทีหลัง open (กัน false breakout ตอนบ่าย)
ORB_RR=1.5             # R:R ของ ORB (1.5 เหมาะ เพราะ range ชัด ความเสี่ยงต่ำ)
