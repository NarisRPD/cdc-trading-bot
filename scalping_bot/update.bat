@echo off
REM ============================================================
REM  update.bat - อัปเดตบอทบน VPS จาก Git แล้วรีสตาร์ทให้อัตโนมัติ
REM  ดับเบิลคลิกตัวนี้บน VPS หลังจากที่เราอัปโค้ด+push จากคอม
REM ============================================================
chcp 65001 >nul
cd /d "%~dp0"
echo === ดึงโค้ดล่าสุดจาก Git ===
git pull
echo.
echo === รีสตาร์ทบอท (kill python เดิม - vps_run.bat จะรีรันด้วยโค้ดใหม่) ===
taskkill /F /IM python.exe >nul 2>&1
echo เสร็จ! บอทจะรีสตาร์ทด้วยโค้ดใหม่ภายใน ~15 วิ (vps_run.bat วนรันให้เอง)
echo เช็ก Telegram ว่าบอทกลับมาทำงาน
pause
